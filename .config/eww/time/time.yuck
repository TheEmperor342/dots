(defpoll time_ :interval "10s"
"date '+%I:%M %p'")

(defwidget contents_ []
  (box :class "time_" time_)
)


(defwindow time
  :monitor 0
  :stacking "bg"
  :windowtype "dock"
  :geometry (geometry :width "30px"
    :height "10px"
  :anchor "top left")
  :reserve (struts :side "top" :distance "4%")
  (contents_)
)
