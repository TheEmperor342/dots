#! /usr/bin/env bash

aa="´äî "
  if [ $(bspc query -D -d focused --names | grep "$1") ]; then
    aa="´íÁ "
  elif [ $(bspc query -D -d .occupied --names | grep "$1") ]; then
    aa="´äæ "
  fi
echo $aa
bspc subscribe desktop node_transfer | while read -r _ ; do
  aa="´äî "
  if [ $(bspc query -D -d focused --names | grep "$1") ]; then
    aa="´íÁ "
  elif [ $(bspc query -D -d .occupied --names | grep "$1") ]; then
    aa="´äæ "
  fi
  echo $aa
done